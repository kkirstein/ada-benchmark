with "config/app_tests_config.gpr";

with "../tasks/tasks.gpr";

project Tests is

   for Source_Dirs use ("src/", "tests/");
   for Object_Dir use "obj/tests/" & App_Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Main use ("tests-run_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use App_Tests_Config.Ada_Compiler_Switches;
   end Compiler;

end Tests;
